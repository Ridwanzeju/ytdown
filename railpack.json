{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "python": "3.12"
  },
  "steps": {
    "install-ytdlp": {
      "commands": [
        "pip install --break-system-packages -U yt-dlp"
      ]
    }
  },
  "deploy": {
    "startCommand": "node server.js"
  }
}
